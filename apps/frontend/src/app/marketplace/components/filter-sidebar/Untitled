<form
  class="bg-white h-screen sticky top-0 shadow-lg w-full md:w-80 overflow-hidden flex flex-col rounded-2xl space-y-4 p-4 md:p-6 z-50"
  [formGroup]="filtersForm">

  <div class="flex items-center justify-between mb-4 relative">
    <h2 class="text-lg font-semibold text-gray-900">Filter by</h2>
    <button type="button" (click)="closeFilters()"
      class="absolute right-0 top-0 text-xl text-gray-700 hover:text-red-600 p-2 focus:outline-none" aria-label="Close">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>

  <!-- Location -->
  <div class="flex flex-col">
    <label for="location" class="text-sm text-gray-700 mb-1 font-medium">Location</label>
    <input id="location" formControlName="location"
      class="bg-gray-50/80 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full px-2.5 py-3 focus:outline-1 focus:ring-2 focus:ring-primary focus:border-primary"
      placeholder="e.g. Nairobi, Mombasa..." />
  </div>

  <!-- Category -->
  <div class="flex flex-col">
    <label for="categoryId" class="text-sm text-gray-700 mb-1 font-medium">Category</label>
    <select id="categoryId" formControlName="categoryId"
      class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary">
      <option value="">Any</option>
      @for (category of categories; track category._id) {
      <option [value]="category._id">{{ category.name }}</option>
      }
    </select>
  </div>

  <!-- Subcategory -->
  <div class="flex flex-col">
    <label for="subcategoryId" class="text-sm text-gray-700 mb-1 font-medium">Subcategory</label>
    <select id="subcategoryId" formControlName="subcategoryId"
      class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary disabled:opacity-50 disabled:cursor-not-allowed">
      <option value="">Any</option>
      @for (sub of filteredSubcategories; track sub._id) {
      <option [value]="sub._id">{{ sub.name }}</option>
      }
    </select>
  </div>

  <!-- Price Range -->
  <div class="grid grid-cols-2 gap-4">
    <div class="flex flex-col">
      <label for="minPrice" class="text-sm text-gray-700 mb-1 font-medium">Min Price</label>
      <input id="minPrice" type="number" formControlName="minPrice"
        class="bg-gray-50/80 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full px-2.5 py-3 focus:outline-1 focus:ring-2 focus:ring-primary focus:border-primary"
        placeholder="Min" min="0" />
    </div>
    <div class="flex flex-col">
      <label for="maxPrice" class="text-sm text-gray-700 mb-1 font-medium">Max Price</label>
      <input id="maxPrice" type="number" formControlName="maxPrice"
        class="bg-gray-50/80 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full px-2.5 py-3 focus:outline-1 focus:ring-2 focus:ring-primary focus:border-primary"
        placeholder="Max" min="0" />
    </div>
  </div>

  <!-- Rating
  <div class="flex flex-col">
    <label for="rating" class="text-sm text-gray-700 mb-1 font-medium">Minimum Rating</label>
    <select id="rating" formControlName="rating"
      class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary">
      <option [value]="null">Any</option>
      <option [value]="1">1 ★ & above</option>
      <option [value]="2">2 ★ & above</option>
      <option [value]="3">3 ★ & above</option>
      <option [value]="4">4 ★ & above</option>
      <option [value]="5">5 ★</option>
    </select>
  </div> -->



  <!-- Actions -->
  <div class="flex flex-row gap-3 justify-between mt-4">
    <app-button (buttonClicked)="resetFilters()" label="Clear all"
      styles="flex-1 !bg-transparent !border !border-red-600 !text-red-600 hover:!bg-red-50" />
    <app-button (buttonClicked)="updateFilters()" label="Apply Filters" styles="flex-1" />
  </div>
</form>